<section class="srt-behind section-{{ section.id }}" style="background-color: {{ section.settings.bg_color }};">
  <div class="container srt-behind__container">
    <div class="srt-behind__header">
      <span class="srt-behind__top-label">{{ section.settings.top_label | upcase }}</span>
      <h2 class="srt-behind__main-title">{{ section.settings.title }}</h2>
    </div>

    <div class="srt-behind__controls">
      <div class="srt-behind__progress-container">
        <div class="srt-behind__progress-bar" id="progress-{{ section.id }}"></div>
      </div>
      <div class="srt-behind__nav">
        <button class="srt-behind__arrow srt-behind__prev" aria-label="Previous">←</button>
        <button class="srt-behind__arrow srt-behind__next" aria-label="Next">→</button>
      </div>
    </div>

    <div class="srt-behind__video-slider" id="behind-slider-{{ section.id }}">
      {% for block in section.blocks %}
        {% if block.type == 'video_slide' %}
          <div class="srt-behind__video-item" {{ block.shopify_attributes }}>
            <div class="srt-behind__video-wrapper">
              {% if block.settings.shopify_video != blank %}
                {{
                  block.settings.shopify_video
                  | video_tag:
                    autoplay: false,
                    loop: false,
                    muted: true,
                    controls: false,
                    class: 'srt-behind__video',
                    image_size: '600x'
                }}
              {% else %}
                {{ 'lifestyle-2' | placeholder_svg_tag: 'srt-behind__video placeholder' }}
              {% endif %}
              <button class="srt-video-play" aria-label="Play video">▶</button>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <div class="srt-behind__grid">
      {% for block in section.blocks %}
        {% if block.type == 'info_card' %}
          <div class="srt-behind__card" {{ block.shopify_attributes }}>
            <span class="srt-behind__card-badge">{{ block.settings.badge | upcase }}</span>
            <h3 class="srt-behind__card-title">{{ block.settings.title }}</h3>
            <p class="srt-behind__card-text">{{ block.settings.text }}</p>
            {% if block.settings.author != blank %}
              <span class="srt-behind__card-author">— {{ block.settings.author }}</span>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .srt-behind { padding: 80px 0; overflow: hidden; }
  .srt-behind__container { max-width: 1420px; margin: auto; padding: 0 20px; }
  .srt-behind__header { text-align: center; margin-bottom: 40px; }
  .srt-behind__top-label { font-size: 14px; letter-spacing: .2em; color: #888; margin-bottom: 10px; display: block; }
  .srt-behind__main-title { font-size: 2.8rem; font-weight: 600; color: #121212; margin: 0; line-height: 1.1; }

  /* Controls */
  .srt-behind__controls { display: flex; align-items: center; justify-content: space-between; margin-bottom: 30px; gap: 40px; }
  .srt-behind__progress-container { flex-grow: 1; height: 2px; background: #e0e0e0; border-radius: 2px; position: relative; overflow: hidden; }
  .srt-behind__progress-bar { position: absolute; top: 0; left: 0; height: 100%; width: 0%; background: #121212; transition: width 0.2s ease; }
  
  .srt-behind__nav { display: flex; gap: 10px; }
  .srt-behind__arrow { 
    width: 44px; height: 44px; border-radius: 50%; border: 1px solid #ddd; 
    background: #fff; cursor: pointer; transition: all 0.3s ease; 
    display: flex; align-items: center; justify-content: center; font-size: 18px;
  }
  .srt-behind__arrow:hover { background: #E3C7B5; color: #000; border-color: #121212; }

  /* Video Carousel */
  .srt-behind__video-slider {
    display: flex; gap: 24px; overflow-x: auto; scroll-behavior: smooth;
    scroll-snap-type: x mandatory; padding-bottom: 10px; margin-bottom: 60px;
    scrollbar-width: none; -ms-overflow-style: none;
  }
  .srt-behind__video-slider::-webkit-scrollbar { display: none; }

  .srt-behind__video-item { 
    flex: 0 0 340px; scroll-snap-align: start; border-radius: 24px; overflow: hidden; 
    will-change: transform; transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  .srt-behind__video-wrapper { position: relative; aspect-ratio: 9/16; background: #f4f4f4; cursor: pointer; }
  .srt-behind__video { width: 100%; height: 100%; object-fit: cover; pointer-events: none; }

  .srt-video-play {
    position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
    width: 65px; height: 65px; border-radius: 50%; border: none;
    background:rgba(227, 199, 181, 0.48); color: #fff; font-size: 22px;
    transition: all 0.3s ease; pointer-events: none; opacity: 1; z-index: 2;
  }

  /* Info Cards */
  .srt-behind__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .srt-behind__card { 
    background: radial-gradient(circle at 18% 15%, rgba(243,230,225,.92), rgba(243,230,225,0) 55%),
                radial-gradient(circle at 85% 90%, rgba(234,208,198,.70), rgba(234,208,198,0) 58%),
                linear-gradient(180deg, rgba(255,255,255,.78), rgba(255,255,255,.55));
    border: 1px solid rgba(255,255,255,0.4); border-radius: 24px; padding: 40px; 
    box-shadow: 0 10px 30px rgba(0,0,0,0.03);
  }
  .srt-behind__card-badge { background: #f4f4f4; color: #121212; font-size: 10px; padding: 5px 12px; border-radius: 100px; font-weight: 700; margin-bottom: 20px; display: inline-block; }
  .srt-behind__card-title { font-size: 1.8rem; margin: 0 0 15px 0; font-weight: 600; }
  .srt-behind__card-text { color: #666; line-height: 1.6; margin-bottom: 20px; }
  .srt-behind__card-author { font-size: 0.9rem; color: #999; font-style: italic; }

  video::-webkit-media-controls { display: none !important; }

  /* Mobile Tweaks - Reduced to 220px */
  @media (max-width: 768px) {
    .srt-behind { padding: 40px 0; }
    .srt-behind__main-title { font-size: 1.8rem; }
    .srt-behind__controls { margin-bottom: 20px; }
    .srt-behind__nav { display: none; }
    
    .srt-behind__video-item { flex: 0 0 220px; border-radius: 18px; }
    .srt-behind__video-slider { gap: 12px; }

    .srt-behind__grid { display: flex; overflow-x: auto; gap: 15px; scroll-snap-type: x mandatory; padding-bottom: 15px; }
    .srt-behind__grid::-webkit-scrollbar { display: none; }
    .srt-behind__card { min-width: 70%; scroll-snap-align: center; padding: 16px; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const slider = document.getElementById('behind-slider-{{ section.id }}');
    const progressBar = document.getElementById('progress-{{ section.id }}');
    const prevBtn = document.querySelector('.srt-behind__prev');
    const nextBtn = document.querySelector('.srt-behind__next');

    const updateProgress = () => {
      const scrollLeft = slider.scrollLeft;
      const maxScroll = slider.scrollWidth - slider.clientWidth;
      if (maxScroll <= 0) return;
      const progress = (scrollLeft / maxScroll) * 100;
      progressBar.style.width = `${progress}%`;
    };

    slider.addEventListener('scroll', updateProgress);

    if (nextBtn && prevBtn) {
      nextBtn.addEventListener('click', () => { slider.scrollBy({ left: 364, behavior: 'smooth' }); });
      prevBtn.addEventListener('click', () => { slider.scrollBy({ left: -364, behavior: 'smooth' }); });
    }

    document.querySelectorAll('.srt-behind__video-wrapper').forEach((wrapper) => {
      const video = wrapper.querySelector('video');
      const btn = wrapper.querySelector('.srt-video-play');
      wrapper.addEventListener('click', () => {
        if (video.paused) {
          video.play();
          btn.innerHTML = '❚❚';
          setTimeout(() => { if(!video.paused) btn.style.opacity = '0'; }, 1000);
        } else {
          video.pause();
          btn.innerHTML = '▶';
          btn.style.opacity = '1';
        }
      });
      wrapper.addEventListener('mouseenter', () => { btn.style.opacity = '1'; });
      wrapper.addEventListener('mouseleave', () => { if(!video.paused) btn.style.opacity = '0'; });
    });
  });
</script>

{% schema %}
{
  "name": "SRT - Behind Video Slider",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#ffffff" },
    { "type": "text", "id": "top_label", "label": "Top Label", "default": "EXPLORE" },
    { "type": "text", "id": "title", "label": "Headline", "default": "Behind The Brush" }
  ],
  "blocks": [
    {
      "type": "video_slide",
      "name": "Carousel Video Item",
      "settings": [{ "type": "video", "id": "shopify_video", "label": "Shopify Hosted Video" }]
    },
    {
      "type": "info_card",
      "name": "Info Card",
      "settings": [
        { "type": "text", "id": "badge", "label": "Badge Text", "default": "THE CRAFT" },
        { "type": "text", "id": "title", "label": "Card Title", "default": "Where Art Meets Skin" },
        { "type": "textarea", "id": "text", "label": "Card Text", "default": "Hand-selected fibers and precision-cut edges." },
        { "type": "text", "id": "author", "label": "Author" }
      ]
    }
  ],
  "presets": [{ "name": "NB - Behind Video Slider" }]
}
{% endschema %}">