{{ 'https://cdn.jsdelivr.net/npm/flickity@2/dist/flickity.min.css' | stylesheet_tag }}
{{ 'https://cdn.jsdelivr.net/npm/flickity@2/dist/flickity.pkgd.min.js' | script_tag }}

<section class="srt-carousel section-{{ section.id }}" style="background-color: {{ section.settings.bg_color }};">
  <div class="container">
    <div class="srt-carousel__header">
      <h2 class="srt-carousel__title">{{ section.settings.title }}</h2>
      <p class="srt-carousel__subtitle">{{ section.settings.subtitle }}</p>
    </div>

    <div class="srt-carousel__slider-container">
      <div
        class="srt-carousel__slider main-carousel"
        id="Slider-{{ section.id }}"
        data-flickity='{ "autoPlay": 5000, "wrapAround": true, "prevNextButtons": true, "pageDots": true, "adaptiveHeight": true }'
      >
        {% for block in section.blocks %}
          {% if block.type == 'product' %}
            {%- assign product = all_products[block.settings.product] -%}
            {%- if product != blank -%}
              <div class="srt-carousel__slide" {{ block.shopify_attributes }}>
                <div class="srt-carousel__card">
                  {% comment %} Dynamic Image Area with Hover Effect {% endcomment %}
                  <div class="srt-carousel__image-area">
                    <a
                      href="{{ product.url }}"
                      class="srt-carousel__image-frame"
                      style="background-color: {{ block.settings.frame_color }};"
                    >
                      {{
                        product.featured_media
                        | image_url: width: 800
                        | image_tag: class: 'srt-carousel__img primary', loading: 'lazy'
                      }}
                      {% if product.media[1] != blank %}
                        {{
                          product.media[1]
                          | image_url: width: 800
                          | image_tag: class: 'srt-carousel__img secondary', loading: 'lazy'
                        }}
                      {% endif %}
                    </a>
                  </div>

                  <div class="srt-carousel__details">
                    <div class="srt-carousel__meta-row">
                      {% comment %} JUDGE.ME DYNAMIC BADGE {% endcomment %}
                      <div class="jdgm-widget jdgm-preview-badge" data-id="{{ product.id }}">
                        {{ product.metafields.judgeme.badge }}
                      </div>

                      {% if product.available %}
                        <span class="srt-carousel__express-tag">In Stock</span>
                      {% endif %}
                    </div>

                    <h3 class="srt-carousel__product-title">
                      <a href="{{ product.url }}">{{ product.title }}</a>
                    </h3>

                    <div class="srt-carousel__description-container">
                      <div class="srt-carousel__product-subtitle" id="desc-{{ block.id }}">
                        {%- assign short_desc = product.description | strip_html | truncatewords: 20 -%}
                        {%- assign full_desc = product.description | strip_html -%}

                        <span class="desc-content">{{ short_desc }}</span>

                        {% if full_desc.size > short_desc.size %}
                          <button
                            type="button"
                            class="srt-see-more"
                            onclick="toggleDescription('{{ block.id }}')"
                            data-fulltext="{{ full_desc | escape }}"
                            data-shorttext="{{ short_desc | escape }}"
                          >
                            See more
                          </button>
                        {% endif %}
                      </div>
                    </div>

                    <p class="srt-carousel__price">
                      {% if product.compare_at_price > product.price %}
                        <span class="srt-price-compare">{{ product.compare_at_price | money }}</span>
                      {% endif %}
                      <span class="srt-price-current">{{ product.price | money }}</span>
                    </p>

                    {% comment %} Dynamic Checklist from Metafields {% endcomment %}
                    {% comment %} <ul class="srt-carousel__checklist">
                      {% if product.metafields.custom.highlights != blank %}
                        {% for highlight in product.metafields.custom.highlights.value %}
                          <li>
                            <svg
                              width="18"
                              height="18"
                              viewBox="0 0 24 24"
                              fill="none"
                              stroke="currentColor"
                              stroke-width="2"
                            >
                              <polyline points="20 6 9 17 4 12"></polyline>
                            </svg>
                            {{ highlight }}
                          </li>
                        {% endfor %}
                      {% else %}
                        <li>
                          <svg
                            width="18"
                            height="18"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                          >
                            <polyline points="20 6 9 17 4 12"></polyline>
                          </svg>
                          Premium Quality Guaranteed
                        </li>
                        <li>
                          <svg
                            width="18"
                            height="18"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                          >
                            <polyline points="20 6 9 17 4 12"></polyline>
                          </svg>
                          Secure Checkout
                        </li>
                      {% endif %}
                    </ul> {% endcomment %}

                    <a href="{{ product.url }}" class="srt-carousel__button">
                      <span>Shop {{ product.price | money_without_trailing_zeros }}</span>
                    </a>
                  </div>
                </div>
              </div>
            {%- endif -%}
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<style>
    .srt-carousel { padding: 80px 0; background-color: #FAEBDF; overflow: hidden; }
    .srt-carousel__header { text-align: center; margin-bottom: 20px; }
    .srt-carousel__title { font-size: 2.8rem; font-weight: 600; color: #121212; margin: 0 0 10px 0; letter-spacing: 0.01em; }
    .srt-carousel__subtitle { font-size: 1.1rem; color: #666; font-weight: 300; max-width: 600px; margin: 0 auto; line-height: 1.6; }

    /* Flickity Overrides */
    .flickity-prev-next-button { width: 44px; height: 44px; background: rgba(255,255,255,0.9); border-radius: 50%; box-shadow: 0 4px 10px rgba(0,0,0,0.1); border: none; }
    .flickity-page-dots { bottom: -40px; }
    .flickity-page-dots .dot { width: 10px; height: 10px; background: #D9B8A3; margin: 0 6px; }

    /* The Card structure */
    .srt-carousel__slide { width: 100%; padding: 20px; box-sizing: border-box; }
    .srt-carousel__card {
      display: grid;
      grid-template-columns: 1fr 1fr;
      background: #ffffff;
      border-radius: 24px;
      padding: 50px;
      gap: 50px;
      box-shadow: 0 20px 50px rgba(0,0,0,0.05);
      max-width: 1100px;
      margin: 0 auto;
      align-items: center;
    }

    /* Image area + Hover swap */
    .srt-carousel__image-frame {
      position: relative;
      border-radius: 16px;
      padding: 30px;
      aspect-ratio: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      text-decoration: none;
    }
    .srt-carousel__img { width: 100%; height: 100%; object-fit: contain; transition: opacity 0.4s ease; }
    .srt-carousel__img.secondary { position: absolute; top: 30px; left: 30px; width: calc(100% - 60px); height: calc(100% - 60px); opacity: 0; }
    .srt-carousel__image-frame:hover .srt-carousel__img.primary { opacity: 0; }
    .srt-carousel__image-frame:hover .srt-carousel__img.secondary { opacity: 1; }

    /* Details */
    .srt-carousel__meta-row { display: flex; align-items: center; gap: 15px; margin-bottom: 15px; }
    .srt-carousel__express-tag { color: #2e7d32; background: #e8f5e9; padding: 4px 12px; border-radius: 100px; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; }

    .srt-carousel__product-title { font-size: 2.2rem; font-weight: 600; margin: 0 0 10px 0; }
    .srt-carousel__product-title a { text-decoration: none; color: #121212; transition: color 0.3s; }
    .srt-carousel__product-title a:hover { color: #D9B8A3; }

  .srt-carousel__product-subtitle {
    font-size: 1rem;
    color: #666;
    line-height: 1.5;
    margin-bottom: 15px;
    transition: all 0.3s ease;
  }
    .srt-carousel__price { font-size: 1.8rem; font-weight: 600; margin-bottom: 25px; }
    .srt-price-compare { text-decoration: line-through; color: #999; font-size: 1.2rem; margin-right: 10px; font-weight: 400; }

    .srt-carousel__checklist { list-style: none; padding: 0; margin: 0 0 35px 0; }
    .srt-carousel__checklist li { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; font-size: 0.95rem; color: #444; }
    .srt-carousel__checklist li svg { color: #D9B8A3; flex-shrink: 0; }

    .srt-carousel__button {
      display: inline-block;
      background: linear-gradient(90deg, #f5e3d6 0%, #d9b8a3 100%);
      color: #121212;
      padding: 16px 40px;
      border-radius: 100px;
      text-decoration: none;
      font-weight: 700;
      transition: all 0.3s;
      text-align: center;
    }
    .srt-carousel__button:hover { transform: translateY(-3px); box-shadow: 0 10px 20px rgba(217,184,163,0.3); }

    /* Judge.me styling */
    .jdgm-prev-badge__stars { color: #f2b01e !important; }
    .jdgm-prev-badge__text { color: #666; font-size: 0.85rem; }
    .srt-see-more {
      background: none;
      border: none;
      color: #D9B8A3; /* Matches your brand accent color */
      font-weight: 600;
      padding: 0;
      margin-left: 5px;
      cursor: pointer;
      text-decoration: underline;
      font-size: 0.9rem;
    }

    .srt-see-more:hover {
      color: #121212;
    }

    /* MOBILE OPTIMIZATION */
    @media (max-width: 768px) {
      .srt-carousel { padding: 40px 0; }
      .srt-carousel__title { font-size: 1.8rem; }
      .srt-carousel__slide { width: 90%; padding: 10px; }
      .srt-carousel__card {
        height: auto;
        min-height: 500px; /* Adjust based on your design preference */
        grid-template-columns: 1fr;
        padding: 25px;
        gap: 20px;
        text-align: center;
        border-radius: 20px;
      }
      .srt-carousel__meta-row { justify-content: center; }
      .srt-carousel__product-title { font-size: 1.4rem; }
      .srt-carousel__checklist { display: none; } /* Keeping it small as requested */
      .srt-carousel__button { width: 100%; box-sizing: border-box; }
      .flickity-prev-next-button { display: none !important; }
      .srt-carousel__image-frame { padding: 15px; }
    }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var elem = document.querySelector('#Slider-{{ section.id }}');
    var flkty = new Flickity(elem, {
      autoPlay: 3000,
      wrapAround: true,
      prevNextButtons: true,
      pageDots: true,
      adaptiveHeight: true,
    });

    // Re-initialize Judge.me on slide changes (important for wrapped slides)
    flkty.on('settle', function () {
      if (window.jdgm) {
        window.jdgm.initializeWidgets();
      }
    });
  });

  function toggleDescription(blockId) {
    const container = document.getElementById('desc-' + blockId);
    const content = container.querySelector('.desc-content');
    const btn = container.querySelector('.srt-see-more');

    if (btn.innerText === 'See more') {
      content.innerText = btn.getAttribute('data-fulltext');
      btn.innerText = 'See less';
    } else {
      content.innerText = btn.getAttribute('data-shorttext');
      btn.innerText = 'See more';
    }

    // Important: Tell Flickity to resize if the text makes the card taller
    var slider = document.querySelector('#Slider-{{ section.id }}');
    var flkty = Flickity.data(slider);
    if (flkty) flkty.reposition();
  }
</script>

{% schema %}
{
  "name": "SRT - Dynamic Carousel",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#FAEBDF" },
    { "type": "text", "id": "title", "label": "Title", "default": "Why people love our products" },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Premium quality craftsmanship, lightning-fast delivery."
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        { "type": "product", "id": "product", "label": "Select Product" },
        { "type": "color", "id": "frame_color", "label": "Image Frame Color", "default": "#F4E1D3" }
      ]
    }
  ],
  "presets": [{ "name": "NB - Dynamic Carousel" }]
}
{% endschema %}
